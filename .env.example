# Gemini API Key for AI enrichment in parser.py
GEMINI_API_KEY=your-gemini-api-key-here

# SysReptor API Key for reptor CLI authentication
REPTOR_API_KEY=your-reptor-api-key-here

# SysReptor Server URL
REPTOR_SERVER=https://your-sysreptor-instance.com

# SysReptor Design ID (required by reptor createproject -d)
REPTOR_DESIGN_ID=your-design-id-here
